generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                    String                   @id @default(cuid())
  clerkOrganizationId   String?                  @unique
  name                  String
  companySize           String?
  hiringFocus           String?
  defaultInterviewMode  String?
  onboardingCompletedAt DateTime?
  createdAt             DateTime                 @default(now())
  jobs                  Job[]
  jobSourceConnections  JobSourceConnection[]
  memberships           OrganizationMembership[]
}

model User {
  id          String                   @id @default(cuid())
  clerkUserId String                   @unique
  email       String                   @unique
  name        String?
  createdAt   DateTime                 @default(now())
  memberships OrganizationMembership[]
}

model OrganizationMembership {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           String
  onboardingRole String?
  status         String       @default("active")
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@unique([organizationId, userId])
  @@index([userId])
}

model Job {
  id               String         @id @default(cuid())
  organizationId   String
  title            String
  location         String?
  description      String         @default("")
  sourceProvider   String?
  sourceExternalId String?
  status           String         @default("draft")
  createdAt        DateTime       @default(now())
  organization     Organization   @relation(fields: [organizationId], references: [id])
  preInterviews    PreInterview[]
  candidates       Candidate[]

  @@index([organizationId, sourceProvider])
}

model JobSourceConnection {
  id             String       @id @default(cuid())
  organizationId String
  provider       String
  status         String
  externalLabel  String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, provider])
  @@index([provider])
}

model PreInterview {
  id          String       @id @default(cuid())
  jobId       String
  status      String       @default("draft")
  publicToken String       @unique
  createdAt   DateTime     @default(now())
  job         Job          @relation(fields: [jobId], references: [id])
  questions   Question[]
  submissions Submission[]
}

model Question {
  id                 String       @id @default(cuid())
  preInterviewId     String
  prompt             String
  expectedSignal     String
  maxDurationSeconds Int          @default(90)
  position           Int
  preInterview       PreInterview @relation(fields: [preInterviewId], references: [id])
  answers            Answer[]
}

model Candidate {
  id          String       @id @default(cuid())
  jobId       String
  fullName    String
  email       String
  status      String       @default("to_review")
  createdAt   DateTime     @default(now())
  job         Job          @relation(fields: [jobId], references: [id])
  submissions Submission[]
}

model Submission {
  id             String       @id @default(cuid())
  candidateId    String
  preInterviewId String
  submittedAt    DateTime     @default(now())
  candidate      Candidate    @relation(fields: [candidateId], references: [id])
  preInterview   PreInterview @relation(fields: [preInterviewId], references: [id])
  answers        Answer[]
}

model Answer {
  id           String     @id @default(cuid())
  submissionId String
  questionId   String
  mode         String
  transcript   String?
  text         String?
  mediaUrl     String?
  submission   Submission @relation(fields: [submissionId], references: [id])
  question     Question   @relation(fields: [questionId], references: [id])
}

model LiveInterviewSession {
  id                String               @id
  interviewPlanId   String               @map("interview_plan_id")
  candidateId       String               @map("candidate_id")
  status            String
  livekitRoomName   String               @map("livekit_room_name")
  allowedModalities Json                 @map("allowed_modalities")
  createdAt         DateTime             @map("created_at")
  updatedAt         DateTime             @map("updated_at")
  events            LiveInterviewEvent[]

  @@map("live_interview_sessions")
}

model LiveInterviewEvent {
  id               String               @id @map("event_id")
  sessionId        String               @map("session_id")
  candidateId      String               @map("candidate_id")
  actor            String
  type             String
  occurredAt       DateTime             @map("occurred_at")
  idempotencyKey   String               @map("idempotency_key")
  sequenceNumber   Int                  @map("sequence_number")
  payload          Json
  providerMetadata Json                 @default("{}") @map("provider_metadata")
  session          LiveInterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, idempotencyKey])
  @@unique([sessionId, sequenceNumber])
  @@index([sessionId, occurredAt, id])
  @@map("live_interview_events")
}
