generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                     String                        @id @default(cuid())
  clerkOrganizationId    String?                       @unique
  name                   String
  companySize            String?
  hiringFocus            String?
  defaultInterviewMode   String?
  settings               Json                          @default("{}")
  onboardingState        Json                          @default("{}")
  onboardingStep         String                        @default("welcome")
  onboardingCompletedAt  DateTime?
  createdAt              DateTime                      @default(now())
  candidateBriefs        CandidateBrief[]
  candidateInvitations   CandidateInvitation[]
  notificationDeliveries NotificationDelivery[]
  candidateReviewEvents  CandidateSessionReviewEvent[]
  candidateSessions      CandidateSession[]
  scheduledCalls         CandidateScheduledCall[]
  connectedAccounts      ConnectedAccount[]
  interviewDrafts        InterviewDraft[]
  interviews             Interview[]
  jobs                   Job[]
  jobSourceConnections   JobSourceConnection[]
  memberships            OrganizationMembership[]
  invitations            OrganizationInvitation[]
}

model User {
  id                                  String                        @id @default(cuid())
  clerkUserId                         String                        @unique
  email                               String                        @unique
  name                                String?
  preferredLanguage                   String                        @default("en")
  createdAt                           DateTime                      @default(now())
  candidateReviewEvents               CandidateSessionReviewEvent[] @relation("CandidateReviewEventAuthor")
  scheduledCalls                      CandidateScheduledCall[]      @relation("CandidateScheduledCallCreatedBy")
  candidateSessionReviewNoteUpdates   CandidateSession[]            @relation("CandidateSessionReviewNoteAuthor")
  candidateSessionReviewStatusUpdates CandidateSession[]            @relation("CandidateSessionReviewStatusAuthor")
  connectedAccounts                   ConnectedAccount[]
  memberships                         OrganizationMembership[]
}

model OrganizationMembership {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           String
  onboardingRole String?
  status         String       @default("active")
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@unique([organizationId, userId])
  @@index([userId])
}

model OrganizationInvitation {
  id              String       @id @default(cuid())
  organizationId  String
  email           String
  role            String
  status          String       @default("pending")
  invitedByUserId String?
  createdAt       DateTime     @default(now())
  acceptedAt      DateTime?
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([organizationId, status])
}

model Job {
  id                   String                @id @default(cuid())
  organizationId       String
  title                String
  location             String?
  description          String                @default("")
  sourceProvider       String?
  sourceExternalId     String?
  status               String                @default("draft")
  createdAt            DateTime              @default(now())
  organization         Organization          @relation(fields: [organizationId], references: [id])
  interviewDrafts      InterviewDraft[]
  interviews           Interview[]
  candidates           Candidate[]
  candidateInvitations CandidateInvitation[]
  candidateSessions    CandidateSession[]

  @@index([organizationId, sourceProvider])
}

model InterviewDraft {
  id                   String       @id @default(cuid())
  organizationId       String
  jobId                String
  status               String       @default("draft")
  roleTitle            String
  roleBrief            String       @default("")
  seniority            String?
  focus                Json         @default("[]")
  responseModes        Json         @default("[]")
  questions            Json         @default("[]")
  criteria             Json         @default("[]")
  guardrails           Json         @default("[]")
  estimatedMinutes     Int?
  rationale            String?
  sourceAttachmentName String?
  schemaVersion        Int          @default(1)
  generatorProvider    String?
  generatorModel       String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  job                  Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  interview            Interview?

  @@index([organizationId, status, updatedAt])
  @@index([jobId, status])
}

model Interview {
  id                   String                @id @default(cuid())
  organizationId       String
  jobId                String
  draftId              String?               @unique
  publicToken          String                @unique
  status               String                @default("published")
  roleTitle            String
  roleBrief            String                @default("")
  seniority            String?
  focus                Json                  @default("[]")
  responseModes        Json                  @default("[]")
  questions            Json                  @default("[]")
  criteria             Json                  @default("[]")
  guardrails           Json                  @default("[]")
  estimatedMinutes     Int?
  rationale            String?
  schemaVersion        Int                   @default(1)
  generatorProvider    String?
  generatorModel       String?
  // N6b: immutable audit record of a recruiter override of an LLM protected-topic
  // flag at publish (null on a clean publish). Append-only; never edited.
  complianceOverride   Json?
  publishedAt          DateTime              @default(now())
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  organization         Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  job                  Job                   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  draft                InterviewDraft?       @relation(fields: [draftId], references: [id], onDelete: SetNull)
  candidateInvitations CandidateInvitation[]
  candidateSessions    CandidateSession[]

  @@index([organizationId, status, updatedAt])
  @@index([jobId, status])
}

// N6b anti-gaming: an append-only, queryable log of every applied LLM
// protected-topic override. Powers the per-recruiter rolling-window rate limit
// and is the foundation for an org-level override-frequency report. Standalone
// (no FK relations) so it stays a pure audit index; rows are never edited.
model ComplianceOverrideEvent {
  id                 String   @id @default(cuid())
  organizationId     String
  interviewId        String?
  overriddenByUserId String
  overriddenByRole   String
  justification      String
  category           String
  classifierProvider String
  classifierModel    String
  createdAt          DateTime @default(now())

  @@index([organizationId, overriddenByUserId, createdAt])
  @@index([organizationId, createdAt])
}

model CandidateInvitation {
  id                 String             @id @default(cuid())
  organizationId     String
  jobId              String
  interviewId        String
  token              String             @unique
  candidateName      String?
  candidateEmail     String?
  status             String             @default("invited")
  expiresAt          DateTime
  openedAt           DateTime?
  consentedAt        DateTime?
  consentCopyVersion String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  job                Job                @relation(fields: [jobId], references: [id], onDelete: Cascade)
  interview          Interview          @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  candidateSessions  CandidateSession[]

  @@index([organizationId, status, expiresAt])
  @@index([interviewId, status])
  @@index([jobId, status])
}

model CandidateSession {
  id                      String                        @id @default(cuid())
  organizationId          String
  jobId                   String
  interviewId             String
  candidateInvitationId   String?
  realtimeSessionId       String?                       @unique
  candidateName           String?
  candidateEmail          String?
  resumeToken             String?                       @unique
  consentedAt             DateTime?
  consentCopyVersion      String?
  status                  String                        @default("created")
  reviewStatus            String                        @default("to_review")
  reviewNote              String?
  reviewStatusUpdatedAt   DateTime?
  reviewStatusUpdatedById String?
  reviewNoteUpdatedAt     DateTime?
  reviewNoteUpdatedById   String?
  startedAt               DateTime?
  completedAt             DateTime?
  createdAt               DateTime                      @default(now())
  updatedAt               DateTime                      @updatedAt
  organization            Organization                  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  job                     Job                           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  interview               Interview                     @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  candidateInvitation     CandidateInvitation?          @relation(fields: [candidateInvitationId], references: [id], onDelete: SetNull)
  candidateBrief          CandidateBrief?
  notificationDeliveries  NotificationDelivery[]
  scheduledCalls          CandidateScheduledCall[]
  reviewEvents            CandidateSessionReviewEvent[]
  reviewStatusUpdatedBy   User?                         @relation("CandidateSessionReviewStatusAuthor", fields: [reviewStatusUpdatedById], references: [id], onDelete: SetNull)
  reviewNoteUpdatedBy     User?                         @relation("CandidateSessionReviewNoteAuthor", fields: [reviewNoteUpdatedById], references: [id], onDelete: SetNull)

  @@index([organizationId, status, updatedAt])
  @@index([organizationId, reviewStatus, updatedAt])
  @@index([jobId, status])
  @@index([interviewId, status])
  @@index([candidateInvitationId, status])
  @@index([reviewStatusUpdatedById])
  @@index([reviewNoteUpdatedById])
}

model CandidateSessionReviewEvent {
  id                 String           @id @default(cuid())
  organizationId     String
  candidateSessionId String
  authorUserId       String
  eventType          String
  previousStatus     String?
  nextStatus         String?
  note               String?
  createdAt          DateTime         @default(now())
  organization       Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  candidateSession   CandidateSession @relation(fields: [candidateSessionId], references: [id], onDelete: Cascade)
  author             User             @relation("CandidateReviewEventAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)

  @@index([candidateSessionId, createdAt])
  @@index([organizationId, createdAt])
  @@index([authorUserId, createdAt])
}

model CandidateBrief {
  id                 String           @id @default(cuid())
  organizationId     String
  candidateSessionId String           @unique
  status             String           @default("pending")
  summaryJson        Json             @default("{}")
  recommendation     String?
  limitations        Json             @default("[]")
  evidence           Json             @default("[]")
  modelProvider      String?
  modelName          String?
  schemaVersion      Int              @default(1)
  generatedAt        DateTime?
  failedReason       String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  organization       Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  candidateSession   CandidateSession @relation(fields: [candidateSessionId], references: [id], onDelete: Cascade)

  @@index([organizationId, status, updatedAt])
}

model NotificationDelivery {
  id                 String                @id @default(cuid())
  organizationId     String
  candidateSessionId String?
  eventType          String
  recipientEmail     String
  dedupeKey          String                @unique
  status             String                @default("pending")
  provider           String?
  providerMessageId  String?
  payloadVersion     Int                   @default(1)
  attemptCount       Int                   @default(0)
  attemptedAt        DateTime?
  sentAt             DateTime?
  skippedAt          DateTime?
  failedAt           DateTime?
  errorCode          String?
  errorSummary       String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  organization       Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  candidateSession   CandidateSession?     @relation(fields: [candidateSessionId], references: [id], onDelete: Cascade)
  attempts           NotificationAttempt[]

  @@index([organizationId, status, updatedAt])
  @@index([candidateSessionId, eventType])
  @@index([recipientEmail, createdAt])
}

model NotificationAttempt {
  id                String               @id @default(cuid())
  notificationId    String
  attemptNumber     Int
  provider          String?
  providerMessageId String?
  status            String
  errorCode         String?
  errorSummary      String?
  createdAt         DateTime             @default(now())
  notification      NotificationDelivery @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@unique([notificationId, attemptNumber])
  @@index([status, createdAt])
}

model JobSourceConnection {
  id             String       @id @default(cuid())
  organizationId String
  provider       String
  status         String
  externalLabel  String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, provider])
  @@index([provider])
}

model ConnectedAccount {
  id                     String                   @id @default(cuid())
  organizationId         String
  userId                 String
  provider               String
  status                 String                   @default("connected")
  capabilities           Json                     @default("[]")
  scopes                 Json                     @default("[]")
  externalAccountId      String?
  externalAccountEmail   String?
  accessTokenCiphertext  String?
  refreshTokenCiphertext String?
  accessTokenExpiresAt   DateTime?
  lastRefreshAttemptAt   DateTime?
  lastRefreshError       String?
  connectedAt            DateTime?
  disconnectedAt         DateTime?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  organization           Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  scheduledCalls         CandidateScheduledCall[]
  user                   User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId, provider])
  @@index([organizationId, provider, status])
  @@index([userId, provider])
}

model CandidateScheduledCall {
  id                    String            @id @default(cuid())
  organizationId        String
  candidateSessionId    String
  createdByUserId       String
  connectedAccountId    String?
  activeScheduleKey     String?           @unique
  provider              String            @default("google_calendar")
  providerCalendarId    String            @default("primary")
  providerEventId       String
  providerEventUrl      String?
  status                String            @default("creating")
  startsAt              DateTime
  endsAt                DateTime
  timeZone              String
  summary               String
  attendeeEmails        Json              @default("[]")
  inviteCandidate       Boolean           @default(false)
  conferenceRequested   Boolean           @default(false)
  conferenceStatus      String?
  location              String?
  conferenceJoinUrl     String?
  lastProviderErrorCode String?
  lastProviderErrorAt   DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  organization          Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  candidateSession      CandidateSession  @relation(fields: [candidateSessionId], references: [id], onDelete: Cascade)
  createdBy             User              @relation("CandidateScheduledCallCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  connectedAccount      ConnectedAccount? @relation(fields: [connectedAccountId], references: [id], onDelete: SetNull)

  @@unique([connectedAccountId, providerCalendarId, providerEventId])
  @@index([organizationId, status, startsAt])
  @@index([candidateSessionId, createdAt])
}

model Candidate {
  id        String   @id @default(cuid())
  jobId     String
  fullName  String
  email     String
  status    String   @default("to_review")
  createdAt DateTime @default(now())
  job       Job      @relation(fields: [jobId], references: [id])
}

model LiveInterviewSession {
  id                String                   @id
  interviewPlanId   String                   @map("interview_plan_id")
  candidateId       String                   @map("candidate_id")
  status            String
  livekitRoomName   String                   @map("livekit_room_name")
  allowedModalities Json                     @map("allowed_modalities")
  createdAt         DateTime                 @map("created_at")
  updatedAt         DateTime                 @map("updated_at")
  events            LiveInterviewEvent[]
  recordings        LiveInterviewRecording[]

  @@map("live_interview_sessions")
}

model LiveInterviewEvent {
  id               String               @id @map("event_id")
  sessionId        String               @map("session_id")
  candidateId      String               @map("candidate_id")
  actor            String
  type             String
  occurredAt       DateTime             @map("occurred_at")
  idempotencyKey   String               @map("idempotency_key")
  sequenceNumber   Int                  @map("sequence_number")
  payload          Json
  providerMetadata Json                 @default("{}") @map("provider_metadata")
  session          LiveInterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, idempotencyKey])
  @@unique([sessionId, sequenceNumber])
  @@index([sessionId, occurredAt, id])
  @@index([sessionId, type, sequenceNumber], map: "live_interview_events_session_id_type_sequence_number_idx")
  @@map("live_interview_events")
}

model LiveInterviewRecording {
  id            String               @id
  sessionId     String               @map("session_id")
  egressId      String?              @unique @map("egress_id")
  objectKey     String?              @map("object_key")
  status        String
  format        String
  layout        String?
  durationMs    Int?                 @map("duration_ms")
  failedReason  String?              @map("failed_reason")
  startedAt     DateTime             @map("started_at")
  endedAt       DateTime?            @map("ended_at")
  createdAt     DateTime             @map("created_at")
  updatedAt     DateTime             @map("updated_at")
  deletedAt     DateTime?            @map("deleted_at")
  deletedReason String?              @map("deleted_reason")
  session       LiveInterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, status])
  @@index([status, endedAt])
  @@map("live_interview_recordings")
}
