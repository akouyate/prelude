# PostgreSQL connection used by packages/db.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/prelude?schema=public"

# Public app URLs used by local E2E tests and cross-app links.
NEXT_PUBLIC_CONSOLE_URL="http://localhost:3000"
NEXT_PUBLIC_CANDIDATE_URL="http://localhost:3001"

# Go realtime API used by the Python interviewer agent and benchmark harness.
REALTIME_API_URL="http://localhost:8080"
REALTIME_API_KEY=""

# LiveKit media plane. Use LiveKit Cloud or a local LiveKit server.
LIVEKIT_URL="wss://..."
LIVEKIT_API_KEY=""
LIVEKIT_API_SECRET=""

# OpenAI Realtime benchmark provider.
OPENAI_API_KEY=""
OPENAI_REALTIME_MODEL="gpt-realtime"
OPENAI_REALTIME_VOICE="marin"
OPENAI_REALTIME_TURN_DETECTION="semantic_vad"
OPENAI_REALTIME_REASONING_EFFORT="low"
OPENAI_REALTIME_TRANSCRIPTION_MODEL="gpt-4o-transcribe"
LIVE_WORKER_MAX_DURATION_SECONDS=""
LIVE_WORKER_CANDIDATE_READY_TIMEOUT_SECONDS="120"
LIVE_WORKER_SOFT_PROMPT_AFTER_SECONDS="10"

# ElevenLabs benchmark provider.
ELEVENLABS_API_KEY=""
ELEVENLABS_AGENT_ID=""
ELEVENLABS_VOICE_ID=""
ELEVENLABS_CONVERSATION_MODE="speech_engine"
ELEVENLABS_TURN_EAGERNESS="normal"

# Benchmark controls.
BENCHMARK_PROVIDER="mock_openai_realtime"
BENCHMARK_RUN_ID=""
BENCHMARK_SCENARIO="normal"
BENCHMARK_ITERATIONS="3"
BENCHMARK_REGION=""
BENCHMARK_PROMPT_VERSION="v1"
