# PostgreSQL connection used by packages/db.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/prelude?schema=public"

# Public app URLs used by local E2E tests and cross-app links.
NEXT_PUBLIC_CONSOLE_URL="http://localhost:3000"
NEXT_PUBLIC_CANDIDATE_URL="http://localhost:3001"

# Clerk V1 console authentication.
# Create a Clerk application, enable Organizations, then copy keys from the Clerk dashboard.
CONSOLE_AUTH_PROVIDER="auto"
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/login"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/onboarding/organization"
# Optional: pre-generated Clerk Testing Token for Playwright real-auth E2E.
CLERK_TESTING_TOKEN=""
# Svix signing secret for the Clerk webhook (Dashboard > Webhooks > your endpoint).
# Required in production to sync Clerk org memberships/invitations into the DB
# via POST /api/clerk/webhook. Subscribe: organizationMembership.* and
# organizationInvitation.*.
CLERK_WEBHOOK_SIGNING_SECRET=""

# First-party connected accounts.
# Generate a 32-byte key with: openssl rand -base64 32
CONNECTED_ACCOUNT_ENCRYPTION_KEY=""
# Optional; defaults to CLERK_SECRET_KEY or the encryption key in production.
CONNECTED_ACCOUNT_STATE_SECRET=""

# Google OAuth web application credentials. Authorized redirect URI:
# http://localhost:3000/api/integrations/google/callback
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI=""

# Transactional notification emails. Disabled by default so local development
# and automated tests never send an external email. Enable explicitly only
# after configuring a verified Resend sender domain.
NOTIFICATIONS_ENABLED="0"
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Prelude.ai <notifications@example.com>"

# Local-only Clerk mock used by the console when CONSOLE_AUTH_PROVIDER is "mock"
# or when CONSOLE_AUTH_PROVIDER is "auto" and Clerk keys are empty.
# The mock is disabled in production. Use Clerk test helpers for real auth E2E.
MOCK_CLERK_USER_ID="user_demo"
MOCK_CLERK_USER_EMAIL="recruiter@prelude.ai"
MOCK_CLERK_USER_NAME="Adrien Kouyate"
MOCK_CLERK_ORG_ID="org_demo"
MOCK_CLERK_ORG_ROLE="owner"

# Go realtime API used by the Python interviewer agent and benchmark harness.
REALTIME_API_URL="http://localhost:8080"
REALTIME_API_KEY=""

# The candidate/console apps reach the Go realtime API via PRELUDE_REALTIME_API_URL
# (a DISTINCT name from REALTIME_API_URL above). In production it MUST be set to
# the deployed realtime service URL, or live interviews fall back to localhost.
PRELUDE_REALTIME_API_URL="http://localhost:8080"

# Production hardening — see docs/operations/production-go-live-runbook.md.
# APP_ENV=production makes the realtime service fail fast on missing
# DB/Redis/LiveKit config and hard-disables every mock interview path.
APP_ENV=""
# Default-deny: a mock (scripted, no-audio) interview runs only when this is
# explicitly true AND APP_ENV is not production. Local smoke runs only.
ALLOW_MOCK_INTERVIEW=""

# Redis ephemeral orchestration for automatic live interviewer dispatch.
REDIS_URL="redis://localhost:6379/0"
AGENT_JOIN_STREAM_KEY="prelude:agent-join:stream"
AGENT_JOIN_PENDING_IDLE_SECONDS="30"
LIVE_WORKER_MAX_CONCURRENCY="2"

# LiveKit media plane. Use LiveKit Cloud or a local LiveKit server.
LIVEKIT_URL="wss://..."
LIVEKIT_API_KEY=""
LIVEKIT_API_SECRET=""

# OpenAI Realtime benchmark provider.
OPENAI_API_KEY=""
INTERVIEW_DRAFT_GENERATOR="openai"
INTERVIEW_DRAFT_LLM_MODEL="gpt-4.1-mini"
INTERVIEW_DRAFT_LLM_TIMEOUT_SECONDS="12"
PROTECTED_TOPIC_CLASSIFIER="openai"
PROTECTED_TOPIC_LLM_MODEL="gpt-4.1-mini"
PROTECTED_TOPIC_LLM_TIMEOUT_SECONDS="6"
OPENAI_REALTIME_MODEL="gpt-realtime"
OPENAI_REALTIME_VOICE="marin"
OPENAI_REALTIME_TURN_DETECTION="semantic_vad"
OPENAI_REALTIME_REASONING_EFFORT="low"
OPENAI_REALTIME_TRANSCRIPTION_MODEL="gpt-4o-transcribe"
OPENAI_ANSWER_INFERENCE_ENABLED="1"
OPENAI_ANSWER_INFERENCE_MODEL="gpt-4.1-mini"
OPENAI_ANSWER_INFERENCE_TIMEOUT_SECONDS="4.0"
LIVE_WORKER_MAX_DURATION_SECONDS=""
LIVE_WORKER_CANDIDATE_READY_TIMEOUT_SECONDS="120"
LIVE_WORKER_SOFT_PROMPT_AFTER_SECONDS="10"

# ElevenLabs benchmark provider.
ELEVENLABS_API_KEY=""
ELEVENLABS_AGENT_ID=""
ELEVENLABS_VOICE_ID=""
ELEVENLABS_CONVERSATION_MODE="speech_engine"
ELEVENLABS_TURN_EAGERNESS="normal"

# Benchmark controls.
BENCHMARK_PROVIDER="mock_openai_realtime"
BENCHMARK_RUN_ID=""
BENCHMARK_SCENARIO="normal"
BENCHMARK_ITERATIONS="3"
BENCHMARK_REGION=""
BENCHMARK_PROMPT_VERSION="v1"
# Keep paid/provider-backed LLM benchmark runs disabled by default.
ALLOW_LIVE_LLM_TESTS="0"
# Private role brief import. Set ROLE_INTAKE_ENABLED=1 only after all R2 and
# ClamAV variables below are configured. Keep this bucket private; no public
# read route is used by Prelude.
ROLE_INTAKE_ENABLED=0
ROLE_INTAKE_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
ROLE_INTAKE_R2_ACCESS_KEY_ID=
ROLE_INTAKE_R2_SECRET_ACCESS_KEY=
ROLE_INTAKE_R2_BUCKET=prelude-role-intakes
ROLE_INTAKE_R2_REGION=auto
ROLE_INTAKE_CLAMAV_HOST=127.0.0.1
ROLE_INTAKE_CLAMAV_PORT=3310
